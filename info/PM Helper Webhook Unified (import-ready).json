    {
      "id": "bb000100-0000-4000-8000-000000000100",
      "name": "Webhook: Kanban Metrics",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        -620
      ],
      "parameters": {
        "httpMethod": "POST",
