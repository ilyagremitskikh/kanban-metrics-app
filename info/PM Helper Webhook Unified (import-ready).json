        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"fields\": {\n    \"project\":     { \"key\": \"CREDITS\" },\n    \"summary\":     $json.summary,\n    \"description\": $json.description,\n    \"issuetype\":   { \"name\": $json.issuetype },\n    \"priority\":    { \"id\": $json.priority },\n    ...($json.labels?.length     ? { \"labels\": $json.labels } : {}),\n    ...($json.slService          ? { \"customfield_21219\": [$json.slService] } : {}),\n    ...($json.productCatalog     ? { \"customfield_22700\": [$json.productCatalog] } : {}),\n    ...($json.needToUpdateSource ? { \"customfield_19879\": { \"value\": $json.needToUpdateSource } } : {}),\n    ...($json.checklists?.length ? { \"customfield_19878\": Array.isArray($json.checklists) ? $json.checklists : [$json.checklists] } : {})\n  }\n} }}",
        "options": {}
