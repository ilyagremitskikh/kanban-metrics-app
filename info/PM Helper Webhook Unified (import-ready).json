      "parameters": {
        "jsCode": "return $input.all().map(({ json }) => ({\n  json: {\n    key: json.key ?? 'Неизвестно',\n    summary: json.fields?.summary ?? json.summary,\n    description: json.fields?.description ?? json.description,\n    status: json.fields?.status?.name ?? json.status,\n    priority: json.fields?.priority?.name ?? json.priority,\n    issuetype: json.fields?.issuetype?.name ?? json.issuetype ?? json.issue_type,\n    reach: json.reach ?? null,\n    impact: json.impact ?? null,\n    confidence: json.confidence ?? null,\n    effort: json.effort ?? null,\n    rice_score: json.rice_score ?? null,\n    bug_risk: json.bug_risk ?? null,\n    bug_process: json.bug_process ?? null,\n    bug_scale: json.bug_scale ?? null,\n    bug_workaround: json.bug_workaround ?? null,\n    bug_score: json.bug_score ?? null,\n    td_impact: json.td_impact ?? null,\n    td_effort: json.td_effort ?? null,\n    td_roi: json.td_roi ?? null,\n    score: json.rice_score ?? json.bug_score ?? json.td_roi ?? null,\n  },\n}));"
      }
    },
    {
      "id": "bb000009-0000-4000-8000-000000000009",
      "name": "Code: Map Create",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        200
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body ?? {};\n\nconst priorityMap = {\n  'Неотложный': '1',\n  'Срочный':    '2',\n  'Высокий':    '3',\n  'Низкий':     '4',\n  'Нормальный': '5',\n  'Средний':    '10000',\n  'Незначительный': '10001',\n};\n\nreturn {\n  json: {\n    summary:            body.summary,\n    description:        body.description,\n    issuetype:          body.issuetype,\n    priority:           priorityMap[body.priority] ?? body.priority,\n    labels:             body.labels,\n    slService:          body.slService,\n    productCatalog:     body.productCatalog,\n    needToUpdateSource: body.needToUpdateSource,\n    checklists:         body.checklists,\n  },\n};"
