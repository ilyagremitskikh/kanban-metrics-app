    {
      "id": "bb000107-0000-4000-8000-000000000107",
      "name": "Code: Issues List Cache Lookup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        60
      ],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst key = 'issues:list:default';\nconst ttlMs = 5 * 60 * 1000;\nconst now = Date.now();\nconst cached = staticData[key];\nif (cached && Array.isArray(cached.issues) && Number(cached.expiresAt) > now) {\n  return [{ json: { cacheHit: true, issues: cached.issues, meta: { fetchedAt: cached.fetchedAt, cached: true, source: 'static-cache' } } }];\n}\nreturn [{ json: { cacheHit: false, cacheKey: key, ttlMs } }];"
      }
