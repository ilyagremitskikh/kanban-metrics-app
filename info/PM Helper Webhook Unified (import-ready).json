    {
      "id": "bb000101-0000-4000-8000-000000000101",
      "name": "Code: Prepare Metrics Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        -620
      ],
      "parameters": {
        "jsCode": "const source = ($json.body && Object.keys($json.body).length ? $json.body : ($json.query ?? {}));\nconst issueTypes = ['User Story', 'Задача', 'Ошибка', 'Техдолг', 'BUSINESS SUB-TASK', 'Подзадача'];\nconst statuses = ['Бэклог', 'Анализ', 'Готово к анализу', 'Готово к разработке', 'Готово к проработке'];\nconst defaultLabel = 'Партнерские_Интеграции';\nconst project = typeof source.project === 'string' ? source.project.trim() : '';\nconst customJqlRaw = typeof source.customJql === 'string' ? source.customJql : (typeof source.jql === 'string' ? source.jql : '');\nconst customJql = customJqlRaw.trim();\n\nlet jql;\nlet cacheKeySource;\n\nif (customJql) {\n  jql = customJql;\n  cacheKeySource = `jql:${customJql}`;\n} else {\n  const normalizedProject = project || 'CREDITS';\n  const issueTypeClause = issueTypes.map((type) => `\"${type}\"`).join(', ');\n  const statusClause = statuses.map((status) => `\"${status}\"`).join(', ');\n  jql = `project = ${normalizedProject} AND issuetype in (${issueTypeClause}) AND status in (${statusClause}) AND labels = ${defaultLabel} ORDER BY created ASC`;\n  cacheKeySource = `project:${normalizedProject}`;\n}\n\nreturn [{ json: { jql, cacheKey: `metrics:${cacheKeySource}`, ttlMs: 10 * 60 * 1000 } }];"
      }
    },
    {
      "id": "bb000102-0000-4000-8000-000000000102",
      "name": "Code: Metrics Cache Lookup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        760,
        -620
      ],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst key = $json.cacheKey;\nconst ttlMs = Number($json.ttlMs ?? 600000);\nconst now = Date.now();\nconst cached = staticData[key];\n\nif (cached && Array.isArray(cached.issues) && Number(cached.expiresAt) > now) {\n  return [{\n    json: {\n      cacheHit: true,\n      issues: cached.issues,\n      meta: {\n        total: cached.issues.length,\n        fetchedAt: cached.fetchedAt,\n        cached: true,\n        cacheKey: key,\n        expiresAt: cached.expiresAt,\n      },\n    },\n  }];\n}\n\nreturn [{ json: { cacheHit: false, jql: $json.jql, cacheKey: key, ttlMs } }];"
      }
    },
    {
      "id": "bb000103-0000-4000-8000-000000000103",
      "name": "If: Metrics Cache Hit",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1000,
        -620
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "if-cache-hit",
              "leftValue": "={{ $json.cacheHit }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "bb000104-0000-4000-8000-000000000104",
      "name": "Jira: Fetch Metrics Issues",
      "type": "n8n-nodes-base.jira",
      "typeVersion": 1,
      "position": [
        1240,
        -520
      ],
      "parameters": {
        "jiraVersion": "serverPat",
        "operation": "getAll",
        "returnAll": true,
        "options": {
          "expand": [
            "changelog"
          ],
          "fields": "summary,issuetype,created,status",
          "jql": "={{ $json.jql }}"
        }
      },
      "credentials": {
        "jiraSoftwareServerPatApi": {
          "id": "5SFlqPVwtO2oNk7Z",
          "name": "Jira Server"
        }
      }
    },
    {
      "id": "bb000105-0000-4000-8000-000000000105",
      "name": "Code: Build Metrics Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1480,
        -520
      ],
      "parameters": {
        "jsCode": "const cacheInput = $('Code: Metrics Cache Lookup').first().json;\nconst staticData = $getWorkflowStaticData('global');\nconst issues = [];\n\nfor (const item of $input.all()) {\n  const issue = item.json;\n  const fields = issue.fields ?? {};\n  const histories = Array.isArray(issue.changelog?.histories) ? [...issue.changelog.histories] : [];\n  histories.sort((a, b) => new Date(a.created).getTime() - new Date(b.created).getTime());\n\n  const transitions = [];\n\n  const firstStatusHistory = histories.find((history) => Array.isArray(history.items) && history.items.some((change) => change.field === 'status'));\n  if (firstStatusHistory) {\n    const firstStatusChange = firstStatusHistory.items.find((change) => change.field === 'status');\n    if (firstStatusChange?.fromString) {\n      transitions.push({\n        to: firstStatusChange.fromString,\n        date: fields.created,\n      });\n    }\n  }\n\n  for (const history of histories) {\n    for (const change of history.items ?? []) {\n      if (change.field !== 'status' || !change.toString || !history.created) continue;\n      transitions.push({\n        to: change.toString,\n        date: history.created,\n        from: change.fromString ?? undefined,\n      });\n    }\n  }\n\n  issues.push({\n    key: issue.key,\n    summary: fields.summary ?? '',\n    type: fields.issuetype?.name ?? 'Unknown',\n    created: fields.created ?? '',\n    currentStatus: fields.status?.name ?? '',\n    transitions,\n  });\n}\n\nconst fetchedAt = new Date().toISOString();\nconst expiresAt = Date.now() + Number(cacheInput.ttlMs ?? 600000);\nstaticData[cacheInput.cacheKey] = { issues, fetchedAt, expiresAt };\n\nreturn [{\n  json: {\n    issues,\n    meta: {\n      total: issues.length,\n      fetchedAt,\n      cached: false,\n      cacheKey: cacheInput.cacheKey,\n      expiresAt,\n    },\n  },\n}];"
      }
    },
    {
      "id": "bb000106-0000-4000-8000-000000000106",
      "name": "Respond: Metrics",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [
        1720,
        -620
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
