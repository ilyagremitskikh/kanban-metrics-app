    {
      "id": "bb000005-0000-4000-8000-000000000005",
      "name": "Code: Build List JQL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        -200
      ],
      "parameters": {
        "jsCode": "const query = $json.query ?? {};\n\nlet jql;\nif (query.jql) {\n  // Произвольный JQL из запроса (?jql=...)\n  jql = query.jql;\n} else if (query.project) {\n  // Фильтр по ключу проекта (?project=CREDITS)\n  jql = 'project = ' + query.project + ' AND issuetype in (\"User Story\", Задача, Ошибка, Техдолг, \"BUSINESS SUB-TASK\", Подзадача) AND status in (Бэклог, Анализ, \"Готово к анализу\", \"Готово к разработке\", \"Готово к проработке\") ORDER BY created ASC';\n} else {\n  // Дефолтный запрос — обратная совместимость\n  jql = 'project = CREDITS AND issuetype in (\"User Story\", Задача, Ошибка, Техдолг, \"BUSINESS SUB-TASK\", Подзадача) AND status in (Бэклог, Анализ, \"Готово к анализу\", \"Готово к разработке\", \"Готово к проработке\") AND labels = Партнерские_Интеграции';\n}\n\nreturn [{ json: { jql } }];"
      }
    },
