                    },
                    "body": {
                      "type": "string"
                    },
                    "created": {
                      "type": "string"
                    }
                  }
                }
              },
              "attachments_info": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "filename": {
                      "type": "string"
                    },
                    "mimeType": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "filename",
                    "mimeType",
                    "url"
                  ]
                }
              },
              "checklists": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ChecklistItem"
                }
              }
            }
          }
        ]
