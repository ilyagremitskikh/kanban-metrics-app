{
  "openapi": "3.1.0",
  "info": {
    "title": "Jira API",
    "description": "Интеграция для работы с задачами Jira (создание, обновление, получение списка/деталей)",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "Issues"
    }
  ],
  "paths": {
    "/jira/issues": {
      "post": {
        "summary": "Create Issue",
        "deprecated": false,
        "description": "",
        "operationId": "create_issue",
        "tags": [
          "Issues"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIssueRequest"
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Issue Successfully Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "key"
                  ]
                },
                "example": {
                  "status": "created",
                  "key": "CREDITS-9023"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      },
      "patch": {
        "summary": "Update Issue",
        "deprecated": false,
        "description": "",
        "operationId": "update_issue",
        "tags": [
          "Issues"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "",
            "required": true,
            "example": "CREDITS-9000",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateIssueRequest"
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Issue Successfully Updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    },
                    "updates": {
                      "type": "object",
                      "properties": {
                        "summary": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": {
                        "type": "string"
                      }
                    }
                  },
                  "required": [
                    "status",
                    "key"
                  ]
                },
                "example": {
                  "status": "updated",
                  "key": "CREDITS-9000",
                  "updates": {
                    "summary": "New Summary",
                    "custom_field_123": "Любое переданное поле"
                  }
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      },
      "get": {
        "summary": "Get Issues List or Detailed Issue",
        "deprecated": false,
        "description": "",
        "operationId": "get_issues",
        "tags": [
          "Issues"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "Передайте ключ задачи для получения детальной информации",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "issues": {
                      "type": "array",
                      "items": {
                        "oneOf": [
                          {
                            "$ref": "#/components/schemas/IssueDetailed"
                          },
                          {
                            "$ref": "#/components/schemas/IssueShort"
                          }
                        ]
                      }
                    }
                  },
                  "required": [
                    "issues"
                  ]
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/ai-generate": {
      "post": {
        "summary": "AI Generate Issue",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "issue_type": {
                    "type": "string"
                  },
                  "user_prompt": {
                    "type": "string"
                  }
                },
                "required": [
                  "issue_type",
                  "user_prompt"
                ]
              },
              "example": {
                "issue_type": "Ошибка",
                "user_prompt": "Кнопка 'скачать отчет' в разделе аналитики метрик потока не работает. Нажимаю и ничего не происходит, просто крутится зеленый лоадер бесконечно. Проверял в хроме и сафари на маке. Надо срочно фиксить, мы не можем выгрузить данные за прошлую неделю!"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "priority": {
                      "type": "string"
                    },
                    "issuetype": {
                      "type": "string"
                    },
                    "checklists": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "checked": {
                            "type": "boolean"
                          },
                          "mandatory": {
                            "type": "boolean"
                          },
                          "rank": {
                            "type": "integer"
                          },
                          "isHeader": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "name",
                          "checked",
                          "mandatory",
                          "rank",
                          "isHeader"
                        ]
                      }
                    }
                  },
                  "required": [
                    "summary",
                    "description",
                    "priority",
                    "issuetype"
                  ]
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/ai-optimize": {
      "post": {
        "summary": "AI Optimize Data",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "field_type": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string"
                  }
                },
                "required": [
                  "field_type",
                  "text"
                ]
              },
              "example": {
                "field_type": "description",
                "text": "Блин, ребята, всё сломалось! 😭 Клиент (ID 109348) пишет что не может привязать карту на лендинге https://n8n.mindhackerdev.ru/promo-spring-2026. Я сам проверил, жму кнопку 'Добавить', крутится лоадер и выпадает ошибка в консоли: TypeError: Cannot read properties of undefined (reading 'payment_token') в файле CheckoutForm.jsx:142. Надо срочно фиксить, мы теряем деньги!!! Сделайте так чтобы ошибка хотя бы обрабатывалась и писала 'Попробуйте позже', а в идеале почините оплату. И еще там в кибане трейс есть: trace_id=9988aabbcc."
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "optimized_text": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "optimized_text"
                  ]
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    }
  },
  "webhooks": {},
  "components": {
    "schemas": {
      "ChecklistItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "checked": {
            "type": "boolean"
          },
          "mandatory": {
            "type": "boolean"
          },
          "id": {
            "type": "integer"
          },
          "rank": {
            "type": "integer"
          },
          "assigneeIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isHeader": {
            "type": "boolean"
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "name",
          "checked",
          "mandatory",
          "rank",
          "isHeader"
        ]
      },
      "CreateIssueRequest": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "issuetype": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "checklists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChecklistItem"
            }
          },
          "needToUpdateSource": {
            "type": "boolean"
          },
          "slService": {
            "type": "string"
          },
          "productCatalog": {
            "type": "string"
          }
        },
        "required": [
          "summary",
          "description",
          "priority",
          "issuetype",
          "needToUpdateSource",
          "slService",
          "productCatalog"
        ]
      },
      "UpdateIssueRequest": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "checklists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChecklistItem"
            }
          },
          "needToUpdateSource": {
            "type": "boolean"
          },
          "slService": {
            "type": "string"
          },
          "productCatalog": {
            "type": "string"
          }
        }
      },
      "IssueShort": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "issuetype": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "assignee": {
            "type": "string"
          },
          "reporter": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created": {
            "type": "string"
          },
          "updated": {
            "type": "string"
          },
          "needToUpdateSource": {
            "type": "boolean"
          },
          "slService": {
            "type": "string"
          },
          "productCatalog": {
            "type": "string"
          }
        },
        "required": [
          "key",
          "summary",
          "status",
          "priority",
          "issuetype"
        ]
      },
      "IssueDetailed": {
        "allOf": [
          {
            "$ref": "#/components/schemas/IssueShort"
          },
          {
            "type": "object",
            "properties": {
              "comments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "author": {
