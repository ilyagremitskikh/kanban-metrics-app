{
  "name": "Kanban AI Agent (OpenRouter)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "kanban-ai",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "e0d37d36-53c0-449d-b6a6-f28a2b5358eb",
      "name": "Webhook POST",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        200,
        300
      ],
      "webhookId": "kanban-ai-agent-webhook"
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.action }}",
        "rules": {
