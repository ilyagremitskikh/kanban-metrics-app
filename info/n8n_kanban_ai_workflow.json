    {
      "parameters": {
        "mode": "json",
        "jsonCode": "let rawText = $input.item.json.text || '{}';\n\n// Убираем markdown обертку ```json ... ``` если LLM ее добавит\nif (rawText.startsWith('```json')) {\n  rawText = rawText.replace(/^```json\\n/, '').replace(/\\n```$/, '');\n} else if (rawText.startsWith('```')) {\n  rawText = rawText.replace(/^```\\n/, '').replace(/\\n```$/, '');\n}\n\ntry {\n  return JSON.parse(rawText);\n} catch (e) {\n  return {\n    error: \"Не удалось распарсить JSON от ИИ\",\n    raw: rawText\n  };\n}"
      },
      "id": "3bb60b13-05b1-41db-b530-9b5bd4cb3b29",
      "name": "Parse LLM JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        300
      ]
    },
    {
