    {
      "id": "bb00000c-0000-4000-8000-000000000012",
      "name": "Code: Map Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 400],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body  = $json.body ?? {};\nconst key   = $json.query?.key;\n\nconst priorityMap = {\n  'Неотложный': '1',\n  'Срочный':    '2',\n  'Высокий':    '3',\n  'Низкий':     '4',\n  'Нормальный': '5',\n  'Средний':    '10000',\n  'Незначительный': '10001',\n};\n\n// Собираем только те поля, которые реально пришли в теле запроса\nconst fields = {\n  ...('summary'     in body ? { summary:     body.summary }     : {}),\n  ...('description' in body ? { description: body.description } : {}),\n  ...('priority'    in body ? { priority: { id: priorityMap[body.priority] ?? body.priority } } : {}),\n  ...('labels'      in body ? { labels:       body.labels }      : {}),\n  ...('checklists'  in body ? { customfield_19878: Array.isArray(body.checklists) ? body.checklists : [body.checklists] } : {}),\n  ...(body.slService          ? { customfield_21219: [body.slService] }                  : {}),\n  ...(body.productCatalog     ? { customfield_22700: [body.productCatalog] }             : {}),\n  ...(body.needToUpdateSource !== undefined ? { customfield_19879: { value: body.needToUpdateSource || 'Нет' } } : {}),\n};\n\nreturn { json: { key, fields } };"
      }
    },
    {
      "id": "bb00000d-0000-4000-8000-000000000013",
