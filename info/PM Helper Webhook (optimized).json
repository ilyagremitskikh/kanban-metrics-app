    {
      "id": "bb000009-0000-4000-8000-000000000009",
      "name": "Code: Map Create",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, 200],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body ?? {};\n\nconst priorityMap = {\n  'Неотложный': '1',\n  'Срочный':    '2',\n  'Высокий':    '3',\n  'Низкий':     '4',\n  'Нормальный': '5',\n  'Средний':    '10000',\n  'Незначительный': '10001',\n};\n\nreturn {\n  json: {\n    summary:            body.summary,\n    description:        body.description,\n    issuetype:          body.issuetype,\n    priority:           priorityMap[body.priority] ?? body.priority,\n    labels:             body.labels,\n    slService:          body.slService,\n    productCatalog:     body.productCatalog,\n    needToUpdateSource: body.needToUpdateSource,\n    checklists:         body.checklists,\n  },\n};"
      }
    },
    {
      "id": "bb00000a-0000-4000-8000-000000000010",
      "name": "HTTP: Create Issue",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [520, 200],
      "parameters": {
        "method": "POST",
        "url": "https://jira.tochka.com/rest/api/2/issue",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "jiraSoftwareServerPatApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"fields\": {\n    \"project\":     { \"key\": \"CREDITS\" },\n    \"summary\":     $json.summary,\n    \"description\": $json.description,\n    \"issuetype\":   { \"name\": $json.issuetype },\n    \"priority\":    { \"id\": $json.priority },\n    ...($json.labels?.length     ? { \"labels\": $json.labels } : {}),\n    ...($json.slService          ? { \"customfield_21219\": [$json.slService] } : {}),\n    ...($json.productCatalog     ? { \"customfield_22700\": [$json.productCatalog] } : {}),\n    ...($json.needToUpdateSource ? { \"customfield_19879\": { \"value\": $json.needToUpdateSource } } : {}),\n    ...($json.checklists?.length ? { \"customfield_19878\": Array.isArray($json.checklists) ? $json.checklists : [$json.checklists] } : {})\n  }\n} }}",
        "options": {}
      },
      "credentials": {
        "jiraSoftwareServerPatApi": {
          "id": "5SFlqPVwtO2oNk7Z",
          "name": "Jira Server"
        }
      }
    },
    {
      "id": "bb00000b-0000-4000-8000-000000000011",
