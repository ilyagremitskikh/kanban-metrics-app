    {
      "id": "bb000003-0000-4000-8000-000000000003",
      "name": "Code: Format Detail",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, -400],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst fields = item.fields ?? {};\n\nconst comments = (fields.comment?.comments ?? []).map(c => ({\n  author: c.author?.displayName ?? 'Неизвестно',\n  body: c.body,\n  created: c.created,\n}));\n\nconst attachments = (fields.attachment ?? []).map(a => ({\n  filename: a.filename,\n  mimeType: a.mimeType,\n  url: a.content,\n}));\n\nreturn [{\n  json: {\n    key: item.key,\n    summary: fields.summary,\n    description: fields.description,\n    status: fields.status?.name,\n    priority: fields.priority?.name,\n    issuetype: fields.issuetype?.name,\n    project: fields.project?.name,\n    assignee: fields.assignee?.displayName ?? null,\n    reporter: fields.reporter?.displayName ?? null,\n    labels: fields.labels ?? [],\n    created: fields.created,\n    updated: fields.updated,\n    comments,\n    attachments_info: attachments,\n    checklists: fields.customfield_19878,\n    needToUpdateSource: fields.customfield_19879?.value === 'Да',\n    slService: fields.customfield_21219?.[0],\n    productCatalog: fields.customfield_22700?.[0],\n  },\n}];"
      }
    },
    {
      "id": "bb000004-0000-4000-8000-000000000004",
      "name": "Respond: Detail",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [1040, -400],
