    {
      "id": "bb000007-0000-4000-8000-000000000007",
      "name": "Code: Format List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, -100],
      "parameters": {
        "jsCode": "return $input.all().map(({ json }) => ({\n  json: {\n    key: json.key ?? 'Неизвестно',\n    summary: json.fields?.summary ?? json.summary,\n    description: json.fields?.description ?? json.description,\n    status: json.fields?.status?.name ?? json.status,\n    priority: json.fields?.priority?.name ?? json.priority,\n    issuetype: json.fields?.issuetype?.name ?? json.issuetype,\n    score: json.rice_score ?? json.bug_score ?? json.td_roi ?? null,\n  },\n}));"
      }
    },
    {
